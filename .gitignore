# Tesseract – Comprehensive .gitignore

# ── Flutter / Dart ───────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
**/*.g.dart
**/*.freezed.dart
**/*.mocks.dart

# ── Android ──────────────────────────────────────────────────
android/.gradle/
android/local.properties
android/key.properties
android/app/release-keystore.jks
android/app/google-services.json
*.jks
*.keystore

# ── iOS ──────────────────────────────────────────────────────
ios/.symlinks/
ios/Pods/
ios/Runner/Generated.xcconfig
ios/Runner/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ServiceDefinitions.json

# ── macOS / Linux / Windows ──────────────────────────────────
bin/
linux/flutter/ephemeral/
macos/Flutter/ephemeral/
windows/flutter/ephemeral/

# ── IDEs & System ────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db
*.log
.kiro/

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example
test_tdlib.dart
.agents/
knowledge/
brain/

# ── Local Windows Build Dependencies ──────────────────────────
node_modules/
package.json
package-lock.json
